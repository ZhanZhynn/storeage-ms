// Prisma schema for Stockly: MongoDB models for users, products, orders, invoices,
// categories, suppliers, warehouses, support tickets, reviews, notifications, etc.
// Run: npx prisma generate (after schema changes); use prisma/client for DB access.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  userId      String    @db.ObjectId // Created by user ID
  workspaceId String?   @db.ObjectId
  status      Boolean   @default(true) // Active/Inactive status (default: active)
  description String? // Optional description field
  notes       String? // Optional notes field
  createdAt   DateTime  @default(now()) @db.Date
  updatedAt   DateTime? @db.Date // Manually managed - null on create, set on update
  createdBy   String    @db.ObjectId // Same as userId, for clarity
  updatedBy   String?   @db.ObjectId // Last updated by user ID
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model Department {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model Invoice {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber String   @unique // Unique invoice number (e.g., INV-2024-001)
  orderId       String   @db.ObjectId @unique // Reference to Order (one-to-one relationship)
  userId        String   @db.ObjectId // User who created the invoice (admin/warehouse user)
  clientId      String?  @db.ObjectId // Client who the invoice is for (optional)
  status        String   @default("draft") // Invoice status: draft, sent, paid, overdue, cancelled
  subtotal      Float    @default(0) // Invoice subtotal (before tax, shipping, discount)
  tax           Float? // Tax amount (optional)
  shipping      Float? // Shipping amount (optional), same as order for transparency
  discount      Float? // Discount amount (optional)
  total         Float    @default(0) // Total amount (subtotal + tax + shipping - discount)
  amountPaid    Float    @default(0) // Amount paid so far (for partial payments)
  amountDue     Float    @default(0) // Amount due (total - amountPaid)
  dueDate       DateTime // Invoice due date
  issuedAt      DateTime @default(now()) @db.Date // Invoice issue date
  sentAt        DateTime? @db.Date // When invoice was sent to client
  paidAt        DateTime? @db.Date // When invoice was paid
  cancelledAt   DateTime? @db.Date // Cancellation date (if cancelled)
  paymentLink   String? // Stripe payment link (optional)
  stripePaymentIntentId String? // Stripe PaymentIntent ID for refunds
  notes         String? // Invoice notes (optional)
  billingAddress Json? // Billing address (JSON object with street, city, state, zipCode, country)
  createdAt     DateTime @default(now()) @db.Date
  updatedAt     DateTime? @db.Date // Manually managed - null on create, set on update
  createdBy     String   @db.ObjectId // Same as userId, for clarity
  updatedBy     String?  @db.ObjectId // Last updated by user ID
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade) // Relation to Order (one-to-one)

  @@index([userId, status, dueDate]) // Index for efficient querying by user, status, and due date
  // orderId already has @unique, so it's automatically indexed
}

model Order {
  id                String      @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber       String      @unique // Unique order number (e.g., ORD-2024-001)
  userId            String      @db.ObjectId // User who created the order (admin/warehouse user)
  clientId          String?     @db.ObjectId // Client who placed the order (optional for now, will be used when client portal is implemented)
  status            String      @default("pending") // Order status: pending, confirmed, processing, shipped, delivered, cancelled
  paymentStatus     String      @default("unpaid") // Payment status: unpaid, paid, refunded, partial
  subtotal          Float       @default(0) // Order subtotal (before tax and shipping)
  tax               Float? // Tax amount (optional)
  shipping          Float? // Shipping cost (optional)
  discount          Float? // Discount amount (optional)
  total             Float       @default(0) // Total amount (subtotal + tax + shipping - discount)
  shippingAddress   Json? // Shipping address (JSON object with street, city, state, zipCode, country)
  billingAddress    Json? // Billing address (JSON object, same structure as shippingAddress)
  notes             String? // Order notes (optional)
  trackingNumber    String? // Shipping tracking number (from Shippo)
  trackingCarrier   String? // Shipping carrier (usps, ups, fedex, dhl, other)
  trackingUrl       String? // Shipping tracking URL (from Shippo)
  labelUrl          String? // Shipping label PDF URL (from Shippo)
  estimatedDelivery DateTime? // Estimated delivery date
  shippedAt         DateTime? // Actual shipping date
  deliveredAt       DateTime? // Actual delivery date
  cancelledAt       DateTime? // Cancellation date (if cancelled)
  stripePaymentIntentId String? // Stripe PaymentIntent ID for refunds
  createdAt         DateTime    @default(now()) @db.Date
  updatedAt         DateTime?   @db.Date // Manually managed - null on create, set on update
  createdBy         String      @db.ObjectId // Same as userId, for clarity
  updatedBy         String?     @db.ObjectId // Last updated by user ID
  items             OrderItem[] // Order items (one-to-many relationship)
  invoice           Invoice? // Invoice for this order (one-to-one relationship)
}

model OrderItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String   @db.ObjectId // Reference to Order
  productId   String   @db.ObjectId // Reference to Product
  productName String // Product name at time of order (snapshot)
  sku         String? // Product SKU at time of order (snapshot)
  quantity    Int // Quantity ordered
  price       Float // Unit price at time of order (snapshot)
  subtotal    Float // Line item subtotal (quantity * price)
  createdAt   DateTime @default(now()) @db.Date
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade) // Cascade delete when order is deleted
  product     Product  @relation(fields: [productId], references: [id]) // Reference to product
}

model Permission {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  /// Field referred in an index, but found no data to define the type.
  resource Json?
  /// Field referred in an index, but found no data to define the type.
  userId   Json?

  @@unique([userId, resource])
}

model Product {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  categoryId       String      @db.ObjectId
  createdAt        DateTime    @default(now()) @db.Date
  updatedAt        DateTime?   @db.Date // Manually managed - null on create, set on update
  name             String
  price            Float
  quantity         BigInt
  reservedQuantity BigInt      @default(0) // Stock reserved by pending orders (not yet confirmed)
  sku              String
  status           String
  supplierId       String      @db.ObjectId
  userId           String      @db.ObjectId // Created by user ID
  workspaceId      String?     @db.ObjectId
  skuScopeId       String      @db.ObjectId // workspaceId for shared products, userId for legacy products
  createdBy        String      @db.ObjectId // Same as userId, for clarity
  updatedBy        String?     @db.ObjectId // Last updated by user ID
  qrCodeUrl        String? // ImageKit URL for QR code image
  qrCodeFileId     String? // ImageKit file ID for cleanup when regenerating
  imageUrl         String? // ImageKit URL for product image
  imageFileId      String? // ImageKit file ID for cleanup when updating/deleting
  expirationDate   DateTime?   @db.Date // Product expiration date (optional, for perishable items)
  deletedAt        DateTime?   @db.Date // Soft-delete: set when product has order history and is "deleted"
  deletedBy        String?     @db.ObjectId // User who soft-deleted the product
  orderItems       OrderItem[] // Orders containing this product (one-to-many relationship)
  channelMappings  ProductChannelMapping[] // Channel links (Shopee, etc.)
  stockMovements   StockMovement[] // Inbound/outbound movement ledger
  workspace        Workspace?  @relation(fields: [workspaceId], references: [id])

  @@index([deletedAt])
  @@unique([skuScopeId, sku])
  @@index([userId, sku])
  @@index([workspaceId])
}

model ProductChannelMapping {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  wmsProductId    String   @db.ObjectId
  channel         String // "shopee", "lazada", "tiktok", etc.
  channelProductId String  @db.ObjectId // FK to ShopeeProduct or ShopeeProductVariant
  channelType     String // "product" or "variant"
  createdAt       DateTime @default(now())

  wmsProduct Product @relation(fields: [wmsProductId], references: [id], onDelete: Cascade)

  @@unique([wmsProductId, channel, channelProductId])
  @@index([channelProductId])
  @@index([wmsProductId])
}

model Session {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  /// Field referred in an index, but found no data to define the type.
  sessionToken Json?  @unique
}

model StockAlert {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model StockAllocation {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  productId        String    @db.ObjectId // Product this allocation is for
  warehouseId      String    @db.ObjectId // Warehouse where stock is located
  quantity         BigInt    @default(0)  // Quantity in this warehouse
  reservedQuantity BigInt    @default(0)  // Reserved stock in this warehouse
  userId           String    @db.ObjectId // User who created this allocation
  workspaceId      String?   @db.ObjectId
  createdAt        DateTime  @default(now()) @db.Date
  updatedAt        DateTime? @db.Date
  workspace        Workspace? @relation(fields: [workspaceId], references: [id])

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@index([workspaceId])
}

// Stock transfer between warehouses
model StockTransfer {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  productId         String    @db.ObjectId // Product being transferred
  fromWarehouseId   String    @db.ObjectId // Source warehouse
  toWarehouseId     String    @db.ObjectId // Destination warehouse
  quantity          BigInt                  // Quantity transferred
  status            String    @default("pending") // pending, completed, cancelled
  notes             String?                 // Optional notes
  userId            String    @db.ObjectId // User who initiated transfer
  createdAt         DateTime  @default(now()) @db.Date
  completedAt       DateTime? @db.Date

  @@index([productId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
}

// Stock movement ledger - tracks every inbound/outbound stock event for audit
model StockMovement {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  productId     String    @db.ObjectId
  warehouseId   String    @db.ObjectId
  quantity      BigInt                  // positive = inbound, negative = outbound
  type          String                  // "in" | "out" | "adjustment" | "transfer"
  sourceType    String?                 // "purchase_order" | "ad_hoc" | "transfer" | "return"
  sourceId      String?   @db.ObjectId  // PO id or transfer id
  poItemId      String?   @db.ObjectId  // specific PO item (for PO-linked receiving)
  receivedById  String    @db.ObjectId  // User who performed the movement
  workspaceId   String?   @db.ObjectId
  receivedAt    DateTime  @default(now()) @db.Date
  notes         String?
  createdAt     DateTime  @default(now()) @db.Date
  user          User      @relation(fields: [receivedById], references: [id])
  product       Product   @relation(fields: [productId], references: [id])
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([productId, warehouseId, receivedAt])
  @@index([sourceType, sourceId])
  @@index([receivedById])
  @@index([warehouseId])
  @@index([workspaceId])
}

model Warehouse {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  address     String?   // Optional address (e.g. full address or location name)
  type        String?   // Optional type: main, secondary, storage, etc.
  status      Boolean   @default(true) // Active/Inactive
  userId      String    @db.ObjectId // Created by user ID
  workspaceId String?   @db.ObjectId
  createdAt   DateTime  @default(now()) @db.Date
  updatedAt   DateTime? @db.Date
  createdBy   String    @db.ObjectId
  updatedBy   String?   @db.ObjectId
  stockMovements StockMovement[]
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([userId])
  @@index([workspaceId])
}

model Supplier {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  userId        String    @db.ObjectId // Created by user ID
  workspaceId   String?   @db.ObjectId
  status        Boolean   @default(true) // Active/Inactive status (default: active)
  description   String? // Optional description field
  notes         String? // Optional notes field
  createdAt     DateTime  @default(now()) @db.Date
  updatedAt     DateTime? @db.Date // Manually managed - null on create, set on update
  createdBy     String    @db.ObjectId // Same as userId, for clarity
  updatedBy     String?   @db.ObjectId // Last updated by user ID
  purchaseOrders PurchaseOrder[]
  evaluations SupplierEvaluation[]
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model User {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt        DateTime  @db.Date
  email            String    @unique
  name             String
  password         String
  updatedAt        DateTime? @db.Date
  username         String?   @unique
  googleId         String? // Google OAuth ID (uniqueness enforced in app logic; @unique removed to avoid non-sparse index blocking null values)
  image            String? // User profile image URL (from Google OAuth or other sources)
  // Role for access control: user, admin, supplier, client, retailer. Optional for backward compatibility; treat null as "user".
  role             String? // user | admin | supplier | client | retailer
  // Account status for approval workflow: pending, approved, rejected. Default "approved" for backward compatibility.
  status           String  @default("approved") // pending | approved | rejected
  // Email notification preferences
  emailPreferences Json? // Email notification preferences stored as JSON
  // Structure: {
  //   lowStockAlerts: boolean,
  //   stockOutNotifications: boolean,
  //   inventoryReports: boolean,
  //   productExpirationWarnings: boolean,
  //   orderConfirmations: boolean,
  //   invoiceEmails: boolean,
  //   shippingNotifications: boolean,
  //   orderStatusUpdates: boolean,
  //   sourcingNotifications: boolean
  // }
  notifications Notification[] // In-app notifications (one-to-many relationship)
  shopeeShops   ShopeeShop[]   // Shopee connected shops (one-to-many relationship)
  lazadaShops   LazadaShop[]   // Lazada connected sellers (one-to-many relationship)
  tiktokShops   TikTokShop[]   // TikTok Shop connected shops (one-to-many relationship)
  shopifyShops  ShopifyShop[]  // Shopify connected shops (one-to-many relationship)
  notificationSetting NotificationSetting? // Telegram notification settings (one-to-one)
  stockMovements StockMovement[] // Stock movements performed by this user
  workspaceMemberships WorkspaceMember[]
  sentWorkspaceInvitations WorkspaceInvitation[] @relation("WorkspaceInvitationSender")
  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
  sourcingComments SourcingComment[]
  sourcingAttachments SourcingAttachment[]
}

model UserAction {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model Workspace {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  ownerId String @db.ObjectId
  baseCurrency String @default("MYR")
  locale String @default("en-MY")
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime? @db.Date
  owner User @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members WorkspaceMember[]
  products Product[]
  categories Category[]
  suppliers Supplier[]
  warehouses Warehouse[]
  purchaseOrders PurchaseOrder[]
  stockAllocations StockAllocation[]
  stockMovements StockMovement[]
  sourcingCases SourcingCase[]
  sourcingQuotes SourcingQuote[]
  sourcingOrders SourcingOrder[]
  sourcingEvents SourcingEvent[]
  sourcingComments SourcingComment[]
  sourcingAttachments SourcingAttachment[]
  purchaseReceipts PurchaseReceipt[]
  supplierEvaluations SupplierEvaluation[]
  invitations WorkspaceInvitation[]

  @@index([ownerId])
}

model WorkspaceMember {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String @db.ObjectId
  userId String @db.ObjectId
  role String // admin | sourcer | warehouse | viewer
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime? @db.Date
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvitation {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String @db.ObjectId
  email String
  name String?
  tokenHash String @unique
  status String @default("pending") // pending | accepted | revoked | expired
  expiresAt DateTime @db.Date
  sentAt DateTime @default(now()) @db.Date
  acceptedAt DateTime? @db.Date
  revokedAt DateTime? @db.Date
  createdById String @db.ObjectId
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User @relation("WorkspaceInvitationSender", fields: [createdById], references: [id])

  @@index([workspaceId, status])
  @@index([email, status])
}

model SourcingCase {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String @db.ObjectId
  title String
  description String?
  photoUrls Json?
  size String?
  material String?
  variant String?
  specifications String?
  referenceUrl String?
  notes String?
  requestedQuantity Int?
  targetUnitPriceMyr Float?
  selectedQuoteId String? @db.ObjectId
  route String @default("yiwu")
  stage String @default("draft")
  version Int @default(1)
  assignedToId String? @db.ObjectId
  nextAction String?
  nextActionAt DateTime? @db.Date
  slaDueAt DateTime? @db.Date
  createdById String @db.ObjectId
  archivedAt DateTime? @db.Date
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime? @db.Date
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  quotes SourcingQuote[]
  orders SourcingOrder[]
  events SourcingEvent[]
  comments SourcingComment[]
  attachments SourcingAttachment[]
  receipts PurchaseReceipt[]

  @@index([workspaceId, stage])
  @@index([workspaceId, assignedToId])
  @@index([workspaceId, nextActionAt])
  @@index([workspaceId, slaDueAt])
}

model SourcingReminder {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  caseId String @db.ObjectId
  userId String @db.ObjectId
  reminderDate DateTime @db.Date
  createdAt DateTime @default(now()) @db.Date

  @@unique([caseId, userId, reminderDate])
  @@index([reminderDate])
}

model SourcingQuote {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String @db.ObjectId
  caseId String @db.ObjectId
  // Stable supplier-offer identity; existing quotes are treated as their own group until backfilled.
  quoteGroupId String? @db.ObjectId
  revision Int
  status String @default("draft")
  supplierName String
  supplierId String? @db.ObjectId
  currency String @default("CNY")
  items Json
  unitPriceRmb Float?
  unitPriceMyr Float?
  fxRate Float?
  fxRateDate DateTime? @db.Date
  fxProvider String?
  fxOverriddenById String? @db.ObjectId
  fxOverrideReason String?
  approvedAt DateTime? @db.Date
  moq Int?
  unitsPerCarton Int?
  cartonDimensions String?
  cartonWeightKg Float?
  leadTimeDays Int?
  validUntil DateTime? @db.Date
  samplePhotoUrls Json?
  paymentTerms String?
  certifications Json?
  complianceNotes String?
  riskLevel String?
  recommendation String?
  priceBreaks Json?
  notes String?
  submittedAt DateTime? @db.Date
  createdById String @db.ObjectId
  createdAt DateTime @default(now()) @db.Date
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourcingCase SourcingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([caseId, revision])
  @@index([workspaceId, caseId])
  @@index([caseId, quoteGroupId])
}

model SourcingOrder {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String @db.ObjectId
  caseId String @db.ObjectId
  quoteId String @db.ObjectId
  purchaseOrderId String? @unique @db.ObjectId
  status String @default("confirmed")
  createdById String @db.ObjectId
  createdAt DateTime @default(now()) @db.Date
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourcingCase SourcingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  receipts PurchaseReceipt[]

  @@index([workspaceId, caseId])
}

model SourcingEvent {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String @db.ObjectId
  caseId String @db.ObjectId
  type String
  actorId String @db.ObjectId
  payload Json?
  createdAt DateTime @default(now()) @db.Date
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourcingCase SourcingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@index([workspaceId, createdAt])
}

model SourcingComment {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String @db.ObjectId
  caseId String @db.ObjectId
  authorId String @db.ObjectId
  body String
  mentionedUserIds Json?
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime? @db.Date
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourcingCase SourcingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([caseId, createdAt])
  @@index([workspaceId, createdAt])
}

model SourcingAttachment {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String @db.ObjectId
  caseId String @db.ObjectId
  uploadedById String @db.ObjectId
  fileName String
  mimeType String
  fileSize Int
  url String
  fileId String
  createdAt DateTime @default(now()) @db.Date
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourcingCase SourcingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([caseId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([uploadedById])
}

model PurchaseReceipt {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String @db.ObjectId
  purchaseOrderId String @db.ObjectId
  sourcingOrderId String? @db.ObjectId
  sourcingCaseId String? @db.ObjectId
  warehouseId String @db.ObjectId
  receivedById String @db.ObjectId
  notes String?
  actualFreightMyr Float @default(0)
  actualDutyMyr Float @default(0)
  actualTaxMyr Float @default(0)
  actualOtherCostMyr Float @default(0)
  actualLandedCostMyr Float @default(0)
  finalizedAt DateTime @default(now()) @db.Date
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  sourcingOrder SourcingOrder? @relation(fields: [sourcingOrderId], references: [id])
  sourcingCase SourcingCase? @relation(fields: [sourcingCaseId], references: [id])
  items PurchaseReceiptItem[]

  @@index([workspaceId, purchaseOrderId])
}

model PurchaseReceiptItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  purchaseReceiptId String @db.ObjectId
  purchaseOrderItemId String @db.ObjectId
  productId String @db.ObjectId
  acceptedQuantity Int @default(0)
  damagedQuantity Int @default(0)
  shortageQuantity Int @default(0)
  qualityStatus String? // accepted | conditional | rejected
  qualityNotes String?
  inspectionPhotoUrls Json?
  allocatedLandedCostMyr Float @default(0)
  unitLandedCostMyr Float?
  notes String?
  receipt PurchaseReceipt @relation(fields: [purchaseReceiptId], references: [id], onDelete: Cascade)

  @@index([purchaseReceiptId])
  @@index([purchaseOrderItemId])
}

model SupplierEvaluation {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String @db.ObjectId
  supplierId String @db.ObjectId
  purchaseOrderId String? @db.ObjectId
  qualityRating Int
  timelinessRating Int
  communicationRating Int
  valueRating Int
  notes String?
  createdById String @db.ObjectId
  createdAt DateTime @default(now()) @db.Date
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([workspaceId, supplierId, createdAt])
  @@index([purchaseOrderId])
}

// Reusable, workspace-scoped starting points for common sourcing requests.
model SourcingTemplate {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String @db.ObjectId
  name String
  data Json
  createdById String @db.ObjectId
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime? @db.Date

  @@unique([workspaceId, name])
  @@index([workspaceId])
