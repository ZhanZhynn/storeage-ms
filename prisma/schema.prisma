// Prisma schema for Stockly: MongoDB models for users, products, orders, invoices,
// categories, suppliers, warehouses, support tickets, reviews, notifications, etc.
// Run: npx prisma generate (after schema changes); use prisma/client for DB access.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  userId      String    @db.ObjectId // Created by user ID
  status      Boolean   @default(true) // Active/Inactive status (default: active)
  description String? // Optional description field
  notes       String? // Optional notes field
  createdAt   DateTime  @default(now()) @db.Date
  updatedAt   DateTime? @db.Date // Manually managed - null on create, set on update
  createdBy   String    @db.ObjectId // Same as userId, for clarity
  updatedBy   String?   @db.ObjectId // Last updated by user ID
}

model Department {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model Invoice {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber String   @unique // Unique invoice number (e.g., INV-2024-001)
  orderId       String   @db.ObjectId @unique // Reference to Order (one-to-one relationship)
  userId        String   @db.ObjectId // User who created the invoice (admin/warehouse user)
  clientId      String?  @db.ObjectId // Client who the invoice is for (optional)
  status        String   @default("draft") // Invoice status: draft, sent, paid, overdue, cancelled
  subtotal      Float    @default(0) // Invoice subtotal (before tax, shipping, discount)
  tax           Float? // Tax amount (optional)
  shipping      Float? // Shipping amount (optional), same as order for transparency
  discount      Float? // Discount amount (optional)
  total         Float    @default(0) // Total amount (subtotal + tax + shipping - discount)
  amountPaid    Float    @default(0) // Amount paid so far (for partial payments)
  amountDue     Float    @default(0) // Amount due (total - amountPaid)
  dueDate       DateTime // Invoice due date
  issuedAt      DateTime @default(now()) @db.Date // Invoice issue date
  sentAt        DateTime? @db.Date // When invoice was sent to client
  paidAt        DateTime? @db.Date // When invoice was paid
  cancelledAt   DateTime? @db.Date // Cancellation date (if cancelled)
  paymentLink   String? // Stripe payment link (optional)
  stripePaymentIntentId String? // Stripe PaymentIntent ID for refunds
  notes         String? // Invoice notes (optional)
  billingAddress Json? // Billing address (JSON object with street, city, state, zipCode, country)
  createdAt     DateTime @default(now()) @db.Date
  updatedAt     DateTime? @db.Date // Manually managed - null on create, set on update
  createdBy     String   @db.ObjectId // Same as userId, for clarity
  updatedBy     String?  @db.ObjectId // Last updated by user ID
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade) // Relation to Order (one-to-one)

  @@index([userId, status, dueDate]) // Index for efficient querying by user, status, and due date
  // orderId already has @unique, so it's automatically indexed
}

model Order {
  id                String      @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber       String      @unique // Unique order number (e.g., ORD-2024-001)
  userId            String      @db.ObjectId // User who created the order (admin/warehouse user)
  clientId          String?     @db.ObjectId // Client who placed the order (optional for now, will be used when client portal is implemented)
  status            String      @default("pending") // Order status: pending, confirmed, processing, shipped, delivered, cancelled
  paymentStatus     String      @default("unpaid") // Payment status: unpaid, paid, refunded, partial
  subtotal          Float       @default(0) // Order subtotal (before tax and shipping)
  tax               Float? // Tax amount (optional)
  shipping          Float? // Shipping cost (optional)
  discount          Float? // Discount amount (optional)
  total             Float       @default(0) // Total amount (subtotal + tax + shipping - discount)
  shippingAddress   Json? // Shipping address (JSON object with street, city, state, zipCode, country)
  billingAddress    Json? // Billing address (JSON object, same structure as shippingAddress)
  notes             String? // Order notes (optional)
  trackingNumber    String? // Shipping tracking number (from Shippo)
  trackingCarrier   String? // Shipping carrier (usps, ups, fedex, dhl, other)
  trackingUrl       String? // Shipping tracking URL (from Shippo)
  labelUrl          String? // Shipping label PDF URL (from Shippo)
  estimatedDelivery DateTime? // Estimated delivery date
  shippedAt         DateTime? // Actual shipping date
  deliveredAt       DateTime? // Actual delivery date
  cancelledAt       DateTime? // Cancellation date (if cancelled)
  stripePaymentIntentId String? // Stripe PaymentIntent ID for refunds
  createdAt         DateTime    @default(now()) @db.Date
  updatedAt         DateTime?   @db.Date // Manually managed - null on create, set on update
  createdBy         String      @db.ObjectId // Same as userId, for clarity
  updatedBy         String?     @db.ObjectId // Last updated by user ID
  items             OrderItem[] // Order items (one-to-many relationship)
  invoice           Invoice? // Invoice for this order (one-to-one relationship)
}

model OrderItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String   @db.ObjectId // Reference to Order
  productId   String   @db.ObjectId // Reference to Product
  productName String // Product name at time of order (snapshot)
  sku         String? // Product SKU at time of order (snapshot)
  quantity    Int // Quantity ordered
  price       Float // Unit price at time of order (snapshot)
  subtotal    Float // Line item subtotal (quantity * price)
  createdAt   DateTime @default(now()) @db.Date
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade) // Cascade delete when order is deleted
  product     Product  @relation(fields: [productId], references: [id]) // Reference to product
}

model Permission {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  /// Field referred in an index, but found no data to define the type.
  resource Json?
  /// Field referred in an index, but found no data to define the type.
  userId   Json?

  @@unique([userId, resource])
}

model Product {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  categoryId       String      @db.ObjectId
  createdAt        DateTime    @default(now()) @db.Date
  updatedAt        DateTime?   @db.Date // Manually managed - null on create, set on update
  name             String
  price            Float
  quantity         BigInt
  reservedQuantity BigInt      @default(0) // Stock reserved by pending orders (not yet confirmed)
  sku              String      @unique
  status           String
  supplierId       String      @db.ObjectId
  userId           String      @db.ObjectId // Created by user ID
  createdBy        String      @db.ObjectId // Same as userId, for clarity
  updatedBy        String?     @db.ObjectId // Last updated by user ID
  qrCodeUrl        String? // ImageKit URL for QR code image
  qrCodeFileId     String? // ImageKit file ID for cleanup when regenerating
  imageUrl         String? // ImageKit URL for product image
  imageFileId      String? // ImageKit file ID for cleanup when updating/deleting
  expirationDate   DateTime?   @db.Date // Product expiration date (optional, for perishable items)
  deletedAt        DateTime?   @db.Date // Soft-delete: set when product has order history and is "deleted"
  deletedBy        String?     @db.ObjectId // User who soft-deleted the product
  orderItems       OrderItem[] // Orders containing this product (one-to-many relationship)
  channelMappings  ProductChannelMapping[] // Channel links (Shopee, etc.)

  @@index([deletedAt])
}

model ProductChannelMapping {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  wmsProductId    String   @db.ObjectId
  channel         String // "shopee", "lazada", etc.
  channelProductId String  @db.ObjectId // FK to ShopeeProduct or ShopeeProductVariant
  channelType     String // "product" or "variant"
  createdAt       DateTime @default(now())

  wmsProduct Product @relation(fields: [wmsProductId], references: [id], onDelete: Cascade)

  @@unique([wmsProductId, channel, channelProductId])
  @@index([channelProductId])
  @@index([wmsProductId])
}

model Session {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  /// Field referred in an index, but found no data to define the type.
  sessionToken Json?  @unique
}

model StockAlert {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model StockAllocation {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  productId        String    @db.ObjectId // Product this allocation is for
  warehouseId      String    @db.ObjectId // Warehouse where stock is located
  quantity         BigInt    @default(0)  // Quantity in this warehouse
  reservedQuantity BigInt    @default(0)  // Reserved stock in this warehouse
  userId           String    @db.ObjectId // User who created this allocation
  createdAt        DateTime  @default(now()) @db.Date
  updatedAt        DateTime? @db.Date

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
}

// Stock transfer between warehouses
model StockTransfer {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  productId         String    @db.ObjectId // Product being transferred
  fromWarehouseId   String    @db.ObjectId // Source warehouse
  toWarehouseId     String    @db.ObjectId // Destination warehouse
  quantity          BigInt                  // Quantity transferred
  status            String    @default("pending") // pending, completed, cancelled
  notes             String?                 // Optional notes
  userId            String    @db.ObjectId // User who initiated transfer
  createdAt         DateTime  @default(now()) @db.Date
  completedAt       DateTime? @db.Date

  @@index([productId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
}

model Warehouse {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  address     String?   // Optional address (e.g. full address or location name)
  type        String?   // Optional type: main, secondary, storage, etc.
  status      Boolean   @default(true) // Active/Inactive
  userId      String    @db.ObjectId // Created by user ID
  createdAt   DateTime  @default(now()) @db.Date
  updatedAt   DateTime? @db.Date
  createdBy   String    @db.ObjectId
  updatedBy   String?   @db.ObjectId

  @@index([userId])
}

model Supplier {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  userId        String    @db.ObjectId // Created by user ID
  status        Boolean   @default(true) // Active/Inactive status (default: active)
  description   String? // Optional description field
  notes         String? // Optional notes field
  createdAt     DateTime  @default(now()) @db.Date
  updatedAt     DateTime? @db.Date // Manually managed - null on create, set on update
  createdBy     String    @db.ObjectId // Same as userId, for clarity
  updatedBy     String?   @db.ObjectId // Last updated by user ID
  purchaseOrders PurchaseOrder[]
}

model User {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt        DateTime  @db.Date
  email            String    @unique
  name             String
  password         String
  updatedAt        DateTime? @db.Date
  username         String?   @unique
  googleId         String? // Google OAuth ID (uniqueness enforced in app logic; @unique removed to avoid non-sparse index blocking null values)
  image            String? // User profile image URL (from Google OAuth or other sources)
  // Role for access control: user, admin, supplier, client, retailer. Optional for backward compatibility; treat null as "user".
  role             String? // user | admin | supplier | client | retailer
  // Email notification preferences
  emailPreferences Json? // Email notification preferences stored as JSON
  // Structure: {
  //   lowStockAlerts: boolean,
  //   stockOutNotifications: boolean,
  //   inventoryReports: boolean,
  //   productExpirationWarnings: boolean,
  //   orderConfirmations: boolean,
  //   invoiceEmails: boolean,
  //   shippingNotifications: boolean,
  //   orderStatusUpdates: boolean
  // }
  notifications Notification[] // In-app notifications (one-to-many relationship)
  shopeeShops   ShopeeShop[]   // Shopee connected shops (one-to-many relationship)
  notificationSetting NotificationSetting? // Telegram notification settings (one-to-one)
}

model UserAction {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model VerificationToken {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  /// Field referred in an index, but found no data to define the type.
  token Json?  @unique
}

model ImportHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId // User who performed the import
  importType  String   // Type of import: "products", "orders", "suppliers", "categories"
  fileName    String   // Original file name
  fileSize    Int      // File size in bytes
  totalRows   Int      // Total rows in the file
  successRows Int      // Number of successfully imported rows
  failedRows  Int      // Number of failed rows
  errors      Json?    // Array of error messages for failed rows
  status      String   @default("completed") // Import status: "processing", "completed", "failed"
  createdAt   DateTime @default(now()) @db.Date
  completedAt DateTime? @db.Date // When import was completed
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId // User who receives the notification
  type      String   // Notification type: "low_stock", "stock_out", "order_confirmation", "order_status_update", etc.
  title     String   // Notification title
  message   String   // Notification message/content
  link      String?  // Optional link to related resource (e.g., /products/:id, /orders/:id)
  read      Boolean  @default(false) // Whether notification has been read
  createdAt DateTime @default(now()) @db.Date
  readAt    DateTime? @db.Date // When notification was marked as read
  metadata  Json?    // Optional metadata (productId, orderId, etc.)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) // Relation to User model

  @@index([userId, read, createdAt]) // Index for efficient querying by user, read status, and date
}

model SupportTicket {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  subject       String    // Ticket subject
  description   String    // Ticket description/details
  status        String    @default("open") // open, in_progress, resolved, closed
  priority      String    @default("medium") // low, medium, high, urgent
  userId        String    @db.ObjectId // Creator (user who opened the ticket)
  assignedToId  String?   @db.ObjectId // Product owner / admin to handle (set on create by user)
  productId     String?   @db.ObjectId // Optional link to product
  orderId       String?   @db.ObjectId // Optional link to order
  supplierId    String?   @db.ObjectId // Optional link to supplier
  notes         String?   // Internal admin notes
  createdAt     DateTime  @default(now()) @db.Date
  updatedAt     DateTime? @db.Date // Manually managed
  replies       SupportTicketReply[]

  @@index([userId])
  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

model SupportTicketReply {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  ticketId  String   @db.ObjectId
  userId    String   @db.ObjectId // Who wrote the reply
  body      String   // Reply text
  createdAt DateTime @default(now()) @db.Date

  supportTicket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([userId])
  @@index([createdAt])
}

model ProductReview {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  productId    String    @db.ObjectId // Product being reviewed
  userId       String    @db.ObjectId // User who wrote the review
  orderId      String?   @db.ObjectId // Order this review relates to (for one-review-per-purchase)
  orderItemId  String?   @db.ObjectId // Optional: specific order line (one review per order line)
  productName  String    // Snapshot at review time (for list display)
  productSku   String?   // Snapshot at review time
  rating       Int       // 1–5
  comment      String    // Review text
  status       String    @default("pending") // pending, approved, rejected
  createdAt    DateTime  @default(now()) @db.Date
  updatedAt    DateTime? @db.Date // Manually managed

  @@index([productId])
  @@index([orderId, productId, userId])
  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([rating])
  @@index([createdAt])
}

// System Configuration - for app-wide settings managed by admin
model SystemConfig {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  key         String    @unique // Configuration key (e.g., "company_name", "low_stock_threshold")
  value       String    // Configuration value (stored as string, parsed by app)
  type        String    @default("string") // Value type: string, number, boolean, json
  label       String    // Human-readable label
  description String?   // Description of the setting
  category    String    @default("general") // Setting category: general, email, shipping, payment, notifications
  isPublic    Boolean   @default(false) // Whether this setting can be exposed to client
  createdAt   DateTime  @default(now()) @db.Date
  updatedAt   DateTime? @db.Date
  updatedBy   String?   @db.ObjectId // Last updated by user ID

  @@index([category])
  @@index([isPublic])
}

// Audit Log - for tracking user activities and system changes
model AuditLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId // User who performed the action
  action      String    // Action type: create, update, delete, login, logout, etc.
  entityType  String    // Entity type: product, order, invoice, user, etc.
  entityId    String?   @db.ObjectId // Entity ID (if applicable)
  details     Json?     // Additional details (JSON object with changes)
  ipAddress   String?   // IP address of the user
  userAgent   String?   // User agent string
  createdAt   DateTime  @default(now()) @db.Date

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

// =============================================================================
// Shopee Integration Models
// =============================================================================

model ShopeeShop {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String    @db.ObjectId // Owner user
  shopId         Int       // Shopee shop ID (assigned by Shopee)
  shopName       String    // Shop display name
  shopStatus     String    // Shop status from Shopee
  region         String    // Shopee region (GLOBAL, CHINA, BRAZIL)
  merchantId     Int?      // Merchant ID (for merchant-level operations)
  isCb           Boolean?  // Cross-border flag
  expireTime     DateTime? // Shop expiration time
  accessToken    String    // Shopee access token (plaintext, same security model as env secrets)
  refreshToken   String    // Shopee refresh token
  tokenExpiry    DateTime? // When access_token expires (computed from expire_in)
  lastSyncedAt   DateTime? // Last successful sync timestamp
  lowStockThreshold Int @default(10) // Configurable per-shop low-stock threshold
  createdAt      DateTime  @default(now()) @db.Date
  updatedAt      DateTime? @db.Date
  createdBy      String    @db.ObjectId
  updatedBy      String?   @db.ObjectId
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  products       ShopeeProduct[]
  orders         ShopeeOrder[]
  syncLogs       ShopeeSyncLog[]
  returns        ShopeeReturn[]

  @@unique([userId, shopId])
  @@index([userId])
  @@index([shopId])
}

model ShopeeProduct {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  shopId         String    @db.ObjectId // FK to ShopeeShop
  userId         String    @db.ObjectId // Owner user
  shopeeItemId   Int       // Shopee item ID (assigned by Shopee)
  itemName       String    // Product name on Shopee
  description    String?   // Product description
  itemSku        String?   // Seller-input parent SKU (from getItemBaseInfo.item_sku)
  categoryId     Int?      // Shopee category ID
  price          Float     // Current/sale price (from price_info.current_price)
  originalPrice  Float?    // Original/before-discount price (from price_info.original_price)
  stock          Int       // Total stock (from stock_info_v2.summary_info.total_available_stock)
  imageUrl       String?   // Primary image URL
  imageUrls      Json?     // All image URLs (array)
  status         String    // Item status (NORMAL, DELETED, etc.)
  tierVariation  Json?     // Variation axes config (e.g. [{name: "Color", option_list: [...]}])
  weight         Float?    // Weight in grams
  dimension      Json?     // {length, width, height}
  lastSyncedAt   DateTime? // Last sync timestamp
  createdAt      DateTime  @default(now()) @db.Date
  updatedAt      DateTime? @db.Date
  createdBy      String    @db.ObjectId
  updatedBy      String?   @db.ObjectId
  shop           ShopeeShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  variants       ShopeeProductVariant[]

  @@unique([shopId, shopeeItemId])
  @@index([shopId])
  @@index([shopeeItemId])
  @@index([userId])
  @@index([itemSku])
}

model ShopeeProductVariant {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  productId      String    @db.ObjectId // FK to ShopeeProduct
  shopId         String    @db.ObjectId // Denormalized for direct queries
  userId         String    @db.ObjectId
  shopeeItemId   Int       // Denormalized parent item ID
  itemSku        String?   // Denormalized parent SKU (from ShopeeProduct.itemSku)
  modelId        Int       // Shopee model_id
  modelName      String    // e.g. "Red / XL"
  modelSku       String?   // Seller-input variant SKU
  price          Float
  originalPrice  Float?
  stock          Int
  status         String    // MODEL_NORMAL / MODEL_UNAVAILABLE
  tierIndex      Json?     // [0, 1] indices into tier_variation
  weight         Float?
  dimension      Json?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now()) @db.Date
  updatedAt      DateTime?
  createdBy      String    @db.ObjectId
  updatedBy      String?   @db.ObjectId
  product        ShopeeProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems     ShopeeOrderItem[]

  @@unique([productId, modelId])
  @@index([modelSku])
  @@index([itemSku])
  @@index([shopeeItemId])
  @@index([shopId])
  @@index([productId])
}

model ShopeeOrder {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  shopId            String    @db.ObjectId // FK to ShopeeShop
  userId            String    @db.ObjectId // Owner user
  shopeeOrderId     String    @unique // Shopee order SN (e.g., 231204xxxxxx)
  orderStatus       String    // UNPAID, READY_TO_SHIP, PROCESSED, SHIPPED, COMPLETED, CANCELLED
  paymentStatus     String?   // Payment status from Shopee
  totalAmount       Float     // Total order amount
  currency          String?   // Currency code (SGD, MYR, etc.)
  region            String?   // Country code from order (SG, MY, etc.) — NOT masked unlike shippingAddress
  buyerUsername     String?   // Buyer's username
  buyerEmail        String?   // Buyer's email (if available)
  shippingAddress   Json?     // {name, phone, address, city, state, zip_code, country}
  trackingNumber    String?   // Shopee tracking number
  trackingCarrier   String?   // Logistics carrier
  logisticsStatus   String?   // Logistics status
  createdAt         DateTime  @default(now()) @db.Date
  updatedAt         DateTime? @db.Date
  createdBy         String    @db.ObjectId
  updatedBy         String?   @db.ObjectId
  lastSyncedAt      DateTime? // Last sync timestamp
  // Shopee timestamps
  shopeeCreatedAt   DateTime? // Original create time on Shopee
  shopeeUpdatedAt   DateTime? // Original update time on Shopee
  paidAt            DateTime? // Payment time
  shippedAt         DateTime? // Shipping time
  deliveredAt       DateTime? // Delivery time
  completedAt       DateTime? // Completion time
  cancelledAt       DateTime? // Cancellation time
  // Fee/commission tracking (from Shopee escrow detail)
  commissionFee     Float?    @default(0) // Shopee platform commission
  serviceFee        Float?    @default(0) // Shopee service fee
  sellerTxnFee      Float?    @default(0) // Seller transaction fee
  shippingFee       Float?    @default(0) // Actual shipping fee (from escrow)
  estimatedShippingFee Float? @default(0) // Estimated shipping fee (from escrow) — compare with actual to find weight/dimension issues
  sellerIncome      Float?    @default(0) // Net seller income after all fees
  buyerPaymentMethod String?  // Payment method used by buyer
  // SLA / shipping deadline tracking (from getPackageDetail)
  shipByDate        DateTime? // Ship-by deadline (Unix seconds from Shopee)
  packageNumber     String?   // Shopee package number for logistics
  fulfillmentStatus String?   // Package fulfillment status (e.g., LOGISTICS_READY)
  daysToShip        Int?      // Days allowed to ship from order creation
  shop              ShopeeShop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items             ShopeeOrderItem[]

  @@index([shopId])
  @@index([userId])
  @@index([orderStatus])
  @@index([shopeeCreatedAt])
  @@index([createdAt])
  @@index([shipByDate])
}

model ShopeeOrderItem {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId          String   @db.ObjectId // FK to ShopeeOrder
  productId        String?  @db.ObjectId // Optional link to local Product (for cross-reference)
  variantId        String?  @db.ObjectId // FK to ShopeeProductVariant (denormalized link)
  shopeeModelId    Int?     // Shopee model ID (variant)
  productName      String   // Product name snapshot
  sku              String?  // SKU snapshot
  quantity         Int      // Ordered quantity
  price            Float    // Unit price
  subtotal         Float    // quantity * price
  createdAt        DateTime @default(now()) @db.Date
  order            ShopeeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant          ShopeeProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model ShopeeSyncLog {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  shopId           String    @db.ObjectId // FK to ShopeeShop
  userId           String    @db.ObjectId // Who triggered the sync
  syncType         String    // "products", "orders", "all"
  status           String    @default("running") // "running", "completed", "completed_with_errors", "failed"
  itemsSynced      Int       @default(0) // Total items processed
  itemsCreated     Int       @default(0) // New items created
  itemsUpdated     Int       @default(0) // Existing items updated
  errors           Json?     // Array of error messages
  startedAt        DateTime  @default(now()) @db.Date
  completedAt      DateTime? @db.Date
  triggeredBy      String    @default("manual") // "manual", "cron", "webhook"
  shop             ShopeeShop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([userId])
  @@index([userId, shopId])
  @@index([status])
  @@index([startedAt])
}

model ShopeeReturn {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  shopId                String    @db.ObjectId
  userId                String    @db.ObjectId
  returnSn              String    @unique // Shopee return serial number
  orderSn               String    // FK to ShopeeOrder.shopeeOrderId
  status                String    // REQUESTED, PROCESSING, ACCEPTED, COMPLETED, CANCELLED
  refundAmount          Float     @default(0)
  currency              String?
  reason                String?
  textReason            String?
  trackingNumber        String?
  needsLogistics        Boolean   @default(false)
  amountBeforeDiscount  Float?    @default(0)
  negotiationStatus     String?
  sellerProofStatus     String?
  sellerCompensationStatus String?
  returnRefundType      String?
  returnSolution        Int?
  returnRefundRequestType Int?
  validationType        String?
  returnShipDueDate     DateTime?
  returnSellerDueDate   DateTime?
  images                Json?     // Array of image URLs
  items                 Json?     // Array of ReturnItem { model_id, name, images, amount, item_price }
  buyerUsername         String?
  buyerEmail            String?
  shopeeCreatedAt       DateTime?
  shopeeUpdatedAt       DateTime?
  createdAt             DateTime  @default(now()) @db.Date
  updatedAt             DateTime? @updatedAt @db.Date
  shop                  ShopeeShop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([orderSn])
  @@index([status])
  @@index([shopeeCreatedAt])
}

model NotificationSetting {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  userId             String    @unique @db.ObjectId // One setting per user
  telegramBotToken   String?   // Telegram Bot API token
  telegramChatId     String?   // Telegram chat/group ID
  telegramEnabled    Boolean   @default(false) // Master toggle for Telegram notifications
  createdAt          DateTime  @default(now()) @db.Date
  updatedAt          DateTime? @updatedAt @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  poNumber      String    @unique
  supplierId    String    @db.ObjectId
  userId        String    @db.ObjectId
  status        String    @default("draft") // draft, pending_approval, approved, rejected, ordered, received, cancelled
  totalAmount   Float     @default(0)
  notes         String?
  approvedBy    String?   @db.ObjectId
  approvedAt    DateTime? @db.Date
  orderedAt     DateTime? @db.Date
  receivedAt    DateTime? @db.Date
  cancelledAt   DateTime? @db.Date
  createdAt     DateTime  @default(now()) @db.Date
  updatedAt     DateTime? @db.Date
  createdBy     String    @db.ObjectId
  updatedBy     String?   @db.ObjectId
  supplier      Supplier  @relation(fields: [supplierId], references: [id])
  items         PurchaseOrderItem[]

  @@index([userId])
  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseOrderItem {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  purchaseOrderId String        @db.ObjectId
  productId       String        @db.ObjectId
  productName     String
  sku             String?
  quantity        Int
  unitCost        Float
  subtotal        Float
  createdAt       DateTime      @default(now()) @db.Date
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
}
