{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), geolocation=()" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/shopee/sync/cron",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/shopee/alerts/sla",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/shopee/alerts/low-stock",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/shopee/digest?period=daily",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/shopee/digest?period=weekly",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/lazada/sync/cron",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/tiktok/sync/cron",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/exchange-rates/refresh",
      "schedule": "15 1 * * *"
    },
    {
      "path": "/api/sourcing/reminders/cron",
      "schedule": "0 9 * * *"
    }
  ]
}
